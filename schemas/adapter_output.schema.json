{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StockArithm Adapter Output",
  "type": "object",
  "required": [
    "adapter",
    "rows"
  ],
  "properties": {
    "adapter": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date"
        ],
        "properties": {
          "date": {
            "type": "string"
          },
          "value": {
            "type": [
              "number",
              "null"
            ]
          },
          "count": {
            "type": [
              "number",
              "null"
            ]
          },
          "interest": {
            "type": [
              "number",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
